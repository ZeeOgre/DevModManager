<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Configurations>Debug;Release</Configurations>
    <StartupObject>DmmDep.Modular.Program</StartupObject>
    <AssemblyName>dmmdeps-modular</AssemblyName>
    <DistributionDir>$(MSBuildProjectDirectory)\dist</DistributionDir>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DMM.Core\DMM.Core.csproj" />
    <ProjectReference Include="..\DMM.AssetManagers\DMM.AssetManagers.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>

  <Target Name="CopyDebugOutputToDist" AfterTargets="Build" Condition="'$(DesignTimeBuild)' != 'true'">
    <MakeDir Directories="$(DistributionDir)" Condition="!Exists('$(DistributionDir)')" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(DistributionDir)" SkipUnchangedFiles="true" />
    <Message Text="Copied $(TargetFileName) to $(DistributionDir)" Importance="high" />
  </Target>

</Project>
