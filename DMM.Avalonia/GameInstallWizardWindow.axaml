<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:DMM.Avalonia"
        mc:Ignorable="d"
        x:Class="DMM.Avalonia.GameInstallWizardWindow"
        x:Name="WizardWindow"
        x:DataType="local:GameInstallWizardViewModel"
        Width="1100"
        Height="700"
        Background="#252525"
        Foreground="White"
        Title="Game Install Discovery">
    <Window.Styles>
        <Style Selector="TextBlock"><Setter Property="Foreground" Value="White" /></Style>
        <Style Selector="Button"><Setter Property="Foreground" Value="White" /><Setter Property="Background" Value="#3A3A3A" /></Style>
    </Window.Styles>

    <Grid Margin="14" RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <Border Background="#2B2B2B" Padding="10" CornerRadius="8">
            <StackPanel>
                <TextBlock FontSize="22" FontWeight="Bold" Text="Game Install Wizard" />
                <TextBlock Text="Discover installs from game stores and choose what to manage." />
                <TextBlock IsVisible="{Binding IsFirstRun}" Text="No installs are configured yet. Complete this step before continuing." FontWeight="SemiBold" />
                <TextBlock Text="{Binding ScanStatus}" FontWeight="SemiBold" />
                <ProgressBar IsVisible="{Binding IsScanning}" IsIndeterminate="True" Height="6" Margin="0,6,0,0" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="4">
            <Border Background="#0A3F78" Padding="8" CornerRadius="6,6,0,0">
                <Grid ColumnDefinitions="90,140,220,* ,90" ColumnSpacing="8">
                    <TextBlock Text="Manage" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="GameStore" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="Game" FontWeight="Bold" />
                    <TextBlock Grid.Column="3" Text="InstallPath" FontWeight="Bold" />
                    <TextBlock Grid.Column="4" Text="Edit" FontWeight="Bold" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding CurrentPageItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:GameInstallRecord">
                            <Border Background="#323232" BorderBrush="#4D4D4D" BorderThickness="1" Padding="8">
                                <Grid ColumnDefinitions="90,140,220,* ,90" ColumnSpacing="8">
                                    <CheckBox IsChecked="{Binding Manage}" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding GameStore}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding GameName}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding InstallPath}" VerticalAlignment="Center" />
                                    <Button Grid.Column="4" Content="Open" IsEnabled="{Binding #WizardWindow.DataContext.CanEditInstalls}" CommandParameter="{Binding}" Click="OpenInstall_Click" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Add Unlisted Game" IsEnabled="{Binding CanEditInstalls}" Click="AddUnlistedGame_Click" />
                <Button Content="Scan Again" IsEnabled="{Binding CanEditInstalls}" Click="ScanAgain_Click" />
            </StackPanel>
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{Binding PageSummary}" />
            <Button Grid.Column="2" Content="◀ Previous" IsEnabled="{Binding CanGoPrevious}" Click="PreviousPage_Click" />
            <Button Grid.Column="3" Content="Next ▶" IsEnabled="{Binding CanGoNext}" Click="NextPage_Click" />
            <Button Grid.Column="4" Content="Save Selection" IsEnabled="{Binding CanEditInstalls}" Click="SaveSelection_Click" />
        </Grid>
    </Grid>
</Window>
