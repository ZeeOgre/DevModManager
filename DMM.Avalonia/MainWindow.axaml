<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:DMM.Avalonia"
        mc:Ignorable="d"
        x:Class="DMM.Avalonia.MainWindow"
        x:DataType="local:MainWindowViewModel"
        Width="1380"
        Height="860"
        MinWidth="1160"
        MinHeight="700"
        Title="DevModManager - Avalonia Prototype"
        Background="#252525"
        Foreground="#F2F4F8">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBackground">#2B2B2B</SolidColorBrush>
        <SolidColorBrush x:Key="PanelBackgroundAlt">#323232</SolidColorBrush>
        <SolidColorBrush x:Key="RowBackgroundPrimary">#2B2B2B</SolidColorBrush>
        <SolidColorBrush x:Key="RowBackgroundAlt">#343434</SolidColorBrush>
        <SolidColorBrush x:Key="RowBorder">#4D4D4D</SolidColorBrush>
        <SolidColorBrush x:Key="HeaderBackground">#0A3F78</SolidColorBrush>
        <SolidColorBrush x:Key="ActionButtonBackground">#3A3A3A</SolidColorBrush>
        <SolidColorBrush x:Key="ActionButtonBorder">#7A7A7A</SolidColorBrush>

        <Style Selector="Button">
            <Setter Property="Foreground" Value="#F2F4F8" />
            <Setter Property="Background" Value="{StaticResource ActionButtonBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource ActionButtonBorder}" />
        </Style>

        <Style Selector="ComboBox">
            <Setter Property="Foreground" Value="#F2F4F8" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#7A7A7A" />
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#F2F4F8" />
        </Style>
    </Window.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="16" RowSpacing="12">
        <Border Background="{StaticResource PanelBackground}" CornerRadius="8" Padding="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="DevModManager" FontSize="30" FontWeight="Bold" Foreground="#FFFFFF" />
                    <TextBlock Text="Track in-development mods, stage progression, and per-mod operations." Opacity="0.96" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Grid.Column="1">
                    <Button Content="Scan Game Folder" Click="ScanGameFolder_Click" />
                    <Button Content="Load Order" Click="LoadOrder_Click" />
                    <Button Content="Settings" Click="OpenSettings_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource PanelBackgroundAlt}" CornerRadius="8" Padding="10">
            <Grid ColumnDefinitions="Auto,300,Auto,Auto,Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                <TextBlock VerticalAlignment="Center" Text="Game Folder:" FontWeight="SemiBold" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding GameFolders}"
                          SelectedItem="{Binding SelectedGameFolder}" />
                <Button Grid.Column="2" Content="Open Game Folder" Click="OpenGameFolder_Click" />
                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Reserved Platform Paths:" FontWeight="SemiBold" />
                <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="XBOX / PS / SWITCH" />
                <TextBlock Grid.Column="5" VerticalAlignment="Center" Text="Core Stages: DEV → TEST → RELEASE (extensible)" />

                <TextBlock Grid.Row="1" Grid.ColumnSpan="6" Opacity="0.96"
                           Text="Core per-mod folders: BACKUP, ModMedia, TifRoot. Stage folders (DEV/TEST/RELEASE/...) each carry data + platform-specific xbox|ps|switch Data trees." />
            </Grid>
        </Border>

        <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="4">
            <Border Background="{StaticResource HeaderBackground}" Padding="10" CornerRadius="6,6,0,0">
                <Grid ColumnDefinitions="3*,1.4*,1.1*,1.3*,1.2*,1.2*,1.4*" ColumnSpacing="8">
                    <TextBlock Text="Mod" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock Grid.Column="1" Text="Primary Plugin" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock Grid.Column="2" Text="Current Stage" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock Grid.Column="3" Text="Backup Folder" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock Grid.Column="4" Text="Bethesda" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock Grid.Column="5" Text="Nexus" FontWeight="SemiBold" Foreground="#FFFFFF" />
                    <TextBlock Grid.Column="6" Text="Actions" FontWeight="SemiBold" Foreground="#FFFFFF" />
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding Mods}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:ModListItem">
                            <Border Background="{Binding RowBackground}"
                                    BorderBrush="{StaticResource RowBorder}"
                                    BorderThickness="1"
                                    Padding="8">
                                <Grid ColumnDefinitions="3*,1.4*,1.1*,1.3*,1.2*,1.2*,1.4*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding PrimaryPlugin}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentStage}" VerticalAlignment="Center" />
                                    <Button Grid.Column="3"
                                            Content="Open Backups"
                                            CommandParameter="{Binding Name}"
                                            Click="OpenBackups_Click" />
                                    <Button Grid.Column="4"
                                            Content="Bethesda"
                                            CommandParameter="{Binding Name}"
                                            Click="OpenBethesda_Click" />
                                    <Button Grid.Column="5"
                                            Content="Nexus"
                                            CommandParameter="{Binding Name}"
                                            Click="OpenNexus_Click" />
                                    <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6">
                                        <Button Content="Focus"
                                                CommandParameter="{Binding}"
                                                Click="OpenModWindow_Click" />
                                        <Button Content="Deploy"
                                                CommandParameter="{Binding Name}"
                                                Click="DeployToGameFolder_Click" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="3" Background="{StaticResource PanelBackgroundAlt}" CornerRadius="8" Padding="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="CK" Click="LaunchCreationKit_Click" />
                <Button Content="xEdit" Click="LaunchXEdit_Click" />
                <Button Content="NifSkope" Click="LaunchNifSkope_Click" />
                <Button Content="AssetWatcher" Click="LaunchAssetWatcher_Click" />
                <Button Content="IDE" Click="LaunchIde_Click" />
                <Button Content="Plugins.txt" Click="OpenPluginsTxt_Click" />
                <Button Content="Load Order" Click="OpenLoadOrderManager_Click" />
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource HeaderBackground}" CornerRadius="8" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FFFFFF" />
        </Border>
    </Grid>
</Window>
